# Example environment variables for development / documentation.
# Do NOT commit real secrets. Replace placeholders with real values locally.

# Database Configuration
MONGODB_URI=REPLACE_WITH_MONGODB_URI

# JWT Configuration
JWT_SECRET=REPLACE_WITH_JWT_SECRET
JWT_EXPIRE=7d

# Server Configuration
PORT=5000
NODE_ENV=production
API_URL=http://localhost:5000

# CORS Configuration
CORS_ORIGIN=https://sensational-chebakia-7234d4.netlify.app

# SMTP Configuration for Email OTP (Using Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=REPLACE_WITH_SMTP_APP_PASSWORD
EMAIL_FROM=your-email@example.com
# Database Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/thenocet-notes?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Server Configuration
PORT=5000
NODE_ENV=production

# CORS Configuration (Update after Netlify deployment)
CORS_ORIGIN=https://your-app.netlify.app

# Email Configuration (Gmail App Password)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your_app_specific_password

# API Base URL (for Render deployment)
API_URL=https://your-api.onrender.com
